// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TransType {
  INCOME
  EXPENSE
  TRANSFER
}

model User {
  id          String    @id @default(ulid())
  name        String
  email       String    @unique
  firebaseUid String?   @unique @map("firebase_uid")
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  deletedBy   String?   @map("deleted_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  telegramChatId String? @unique @map("telegram_chat_id")
  telegramPairingToken String? @unique @map("telegram_pairing_token")
  telegramPairingExpires DateTime? @map("telegram_pairing_expires")

  @@map("users")
}

model Category {
  id           String        @id @default(ulid())
  name         String
  type         TransType
  icon         String
  color        String
  transactions Transaction[]
  isCreatedByAi Boolean      @default(false) @map("is_created_by_ai")
  createdBy    String?       @map("created_by")
  updatedBy    String?       @map("updated_by")
  deletedBy    String?       @map("deleted_by")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  @@map("categories")
}

model Wallet {
  id               String        @id @default(ulid())
  name             String
  icon             String
  color            String
  balance          Float
  fromTransactions Transaction[] @relation("FromWallet")
  toTransactions   Transaction[] @relation("ToWallet")
  isCreatedByAi    Boolean       @default(false) @map("is_created_by_ai")
  createdBy        String?       @map("created_by")
  updatedBy        String?       @map("updated_by")
  deletedBy        String?       @map("deleted_by")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")
  mutations        Mutation[]

  @@map("wallets")
}

model Transaction {
  id           String     @id @default(ulid())
  date         DateTime
  description  String
  categoryId   String     @map("category_id")
  category     Category   @relation(fields: [categoryId], references: [id])
  type         TransType
  fromWalletId String     @map("from_wallet_id")
  fromWallet   Wallet     @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWalletId   String?    @map("to_wallet_id")
  toWallet     Wallet?    @relation("ToWallet", fields: [toWalletId], references: [id])
  amount       Float
  mutations    Mutation[]
  isCreatedByAi Boolean    @default(false) @map("is_created_by_ai")
  createdBy    String?    @map("created_by")
  updatedBy    String?    @map("updated_by")
  deletedBy    String?    @map("deleted_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  @@map("transactions")
}

model Mutation {
  id            String      @id @default(ulid())
  transactionId String      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  walletId      String      @map("wallet_id")
  wallet        Wallet      @relation(fields: [walletId], references: [id])
  amount        Float
  createdBy     String?     @map("created_by")
  updatedBy     String?     @map("updated_by")
  deletedBy     String?     @map("deleted_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  @@map("mutations")
}

model AiChatMessage {
  id            String   @id @default(ulid())
  userId        String   @map("user_id")
  role          String   // 'user' atau 'model'
  message       String   @db.Text
  actionType    String?  @map("action_type") // 'CREATE_TRANSACTION', 'CREATE_CATEGORY', 'CREATE_WALLET', 'GENERAL_CHAT'
  referenceId   String?  @map("reference_id") // ID objek yang berhasil dibuat (transaksi/kategori/dompet)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("ai_chat_messages")
}

